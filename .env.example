# Variables de entorno — copiar a .env y completar

# PostgreSQL (Railway provee DATABASE_URL automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — Cambia esto por una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo_32chars

# Usuario admin inicial (se crea automáticamente si no existe)
ADMIN_USER=admin
ADMIN_PASSWORD=Admin123!

# Puerto (Railway lo asigna automáticamente)
PORT=3000

# Ambiente
NODE_ENV=production
